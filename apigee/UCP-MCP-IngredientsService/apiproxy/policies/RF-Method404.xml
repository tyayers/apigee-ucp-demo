<?xml version="1.0" encoding="UTF-8"?>
<RaiseFault continueOnError="false" enabled="true" name="RF-Method404">
  <DisplayName>RF-Method404</DisplayName>
  <Properties/>
  <FaultResponse>
    <AssignVariable>
      <Name>error_status</Name>
      <Value>200</Value>
    </AssignVariable>
    <AssignVariable>
      <Name>error_body</Name>
      <Template>{
  "jsonrpc": "2.0",
  "id": {mcp.id},
  "error": {
    "code": -32601,
    "message": "Could not find MCP method \"{escapeJSON(mcp.method)}\""
  }
}</Template>
    </AssignVariable>
  </FaultResponse>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
</RaiseFault>
